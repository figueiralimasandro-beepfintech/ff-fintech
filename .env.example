# Finora backend environment configuration (example - do NOT commit real secrets)

# Application
FINORA_APP_NAME=finora
FINORA_APP_ENV=development
FINORA_APP_PORT=3000
FINORA_LOG_LEVEL=info

# Database (example PostgreSQL URL)
FINORA_DATABASE_URL=postgres://finora:password@localhost:5432/finora

# Auth / security
FINORA_JWT_SECRET=replace-with-strong-secret
FINORA_JWT_EXPIRES_IN=15m
FINORA_REFRESH_TOKEN_EXPIRES_IN=7d

# Open Finance / external integrations (IDs only, no real secrets)
FINORA_OPEN_FINANCE_CLIENT_ID=your-open-finance-client-id
FINORA_OPEN_FINANCE_REDIRECT_URI=http://localhost:3000/open-finance/callback

# Observability
FINORA_SENTRY_DSN=
FINORA_METRICS_ENABLED=false
FINORA_METRICS_PORT=9100

# Replace values above in your local .env file (never commit .env)
